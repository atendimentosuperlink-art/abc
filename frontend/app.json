{
  "expo": {
    "name": "Vistoria Diária",
    "slug": "vistoria-diaria",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "vistoria",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Tirar fotos das avarias do veículo",
        "NSPhotoLibraryUsageDescription": "Anexar fotos das avarias do veículo"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#1c1c1e"
      },
      "edgeToEdgeEnabled": true,
      "permissions": ["android.permission.CAMERA", "android.permission.READ_EXTERNAL_STORAGE"]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-image.png",
          "imageWidth": 240,
          "resizeMode": "contain",
          "backgroundColor": "#1c1c1e"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
